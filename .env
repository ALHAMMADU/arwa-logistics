# ─── Database (SQLite for development / PostgreSQL for production) ──
DATABASE_URL="file:/home/z/my-project/db/custom.db"

# ─── Authentication ────────────────────────────────────
JWT_SECRET=arwa-jwt-secret-key-2026-production-change-me
JWT_EXPIRES_IN=7d

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── RabbitMQ ──────────────────────────────────────────
RABBITMQ_URL=amqp://arwa:arwa_rabbitmq_2026@localhost:5672

